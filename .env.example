# ============================================================
# TakumiRoute — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- PostgreSQL + PostGIS ---
POSTGRES_USER=takumi
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=takumiroute
DATABASE_URL=postgresql+asyncpg://takumi:CHANGE_ME_IN_PRODUCTION@postgres:5432/takumiroute

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- OSRM ---
OSRM_URL=http://osrm:5000

# --- Authentication (JWT) ---
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173"]

# --- Sentry (error tracking) ---
SENTRY_DSN=

# --- Agent (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
